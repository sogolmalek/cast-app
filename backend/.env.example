# Cast Backend Configuration

# ── Server ──
PORT=3001
NODE_ENV=development
JWT_SECRET=your-secret-key-change-this-in-production
DB_PATH=./data/cast.db
CORS_ORIGIN=http://localhost:5173

# ── Solana / AUDD (native chain) ──
# AUDD is Australia's fully-backed digital dollar stablecoin, issued as an
# SPL token on Solana. 6 decimals per SPL convention.
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_COMMITMENT=confirmed

# Official AUDD SPL mint address for the chosen network.
# Fill this in with the AUDD mint provided by the AUDD team for devnet/mainnet.
SOLANA_AUDD_MINT=
SOLANA_AUDD_DECIMALS=6

# Cast's recipient wallet — receives AUDD from callers.
# Use a dedicated Solana address for this (not a personal wallet).
SOLANA_RECIPIENT_ADDRESS=

# Server-side signer secret (base58, kept server-side) used for settlement txs
# that pay creators out from the Cast escrow. Do NOT commit a real value.
SOLANA_SIGNER_SECRET=

SOLANA_EXPLORER_URL=https://explorer.solana.com

# ── Base (EVM) ──
BASE_RPC_URL=https://mainnet.base.org
BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
BASE_RECIPIENT_ADDRESS=0x_your_cast_recipient_address
