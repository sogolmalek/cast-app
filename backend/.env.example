# Cast Backend Configuration

# ── Server ──
PORT=3001
NODE_ENV=development
JWT_SECRET=your-secret-key-change-this-in-production
DB_PATH=./data/cast.db
CORS_ORIGIN=http://localhost:5173

# ── Starknet (native chain) ──
STARKNET_RPC_URL=https://starknet-mainnet.public.blastapi.io
STARKNET_CHAIN_ID=SN_MAIN
STARKNET_PAYMENT_CONTRACT=0x_your_deployed_cast_payment_contract
STARKNET_USDC_ADDRESS=0x053c91253bc9682c04929ca02ed00b3e423f6710d2ee7e0d5ebb06f3ecf368a8

# Cast's server-side signer account (for settlements + paymaster execution)
# Generate a dedicated account for this — do NOT use a personal wallet
STARKNET_SIGNER_ADDRESS=0x_your_cast_signer_account
STARKNET_SIGNER_PRIVATE_KEY=0x_private_key_keep_this_secret

# Paymaster (gas sponsorship for callers)
STARKNET_PAYMASTER_ENABLED=false
STARKNET_MAX_GAS_SUBSIDY=0.0005

# Accept pending transactions (faster but less safe)
STARKNET_ACCEPT_PENDING=false

# ── Base (EVM) ──
BASE_RPC_URL=https://mainnet.base.org
BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
BASE_RECIPIENT_ADDRESS=0x_your_cast_recipient_address

# ── X1 EcoChain ──
# Testnet: Chain ID 10778, Explorer: https://maculatus-scan.x1eco.com/
X1_NETWORK=testnet
X1_RPC_URL=https://maculatus-rpc.x1eco.com/
X1_CHAIN_ID=10778
X1_USDT_ADDRESS=0x_usdt_contract_on_x1ecochain
X1_RECIPIENT_ADDRESS=0x_your_cast_recipient_on_x1
X1_EXPLORER_URL=https://maculatus-scan.x1eco.com/
